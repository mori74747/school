EX17	START
	LD	GR1,N
	CPL	GR1,=4
	JPL	QUIT
	LD	GR1,JUMPTB,GR1
	JUMP	0,GR1
;
LBL0	LD	GR2,A
	ADDA	GR2,B
	JUMP	QUIT
;
LBL1	LD	GR2,A
	SUBA	GR2,B
	JUMP	QUIT
;
LBL2	LD	GR2,B
	SUBA	GR2,A
	JUMP	QUIT
;
LBL3	SUBA	GR2,GR2
	SUBA	GR2,A
	JUMP	QUIT
;
LBL4	SUBA	GR2,GR2
	SUBA	GR2,B
	JUMP	QUIT
;
QUIT	ST	GR2,ANS
	RET
;
JUMPTB	DC	LBL0
	DC	LBL1
	DC	LBL2
	DC	LBL3
	DC	LBL4
;
A	DC	64
B	DC	1287
N	DC	3
ANS	DS	1
	END