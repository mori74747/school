EX16	START
	LD	GR1,SCORE
	CPL	GR1,=20
	JMI	LBL1
	CPL	GR1,=40
	JMI	LBL2
	CPL	GR1,=60
	JMI	LBL3
	CPL	GR1,=80
	JMI	LBL4
	JUMP	LBL5
;
LBL1	LAD	GR0,1
	JUMP	QUIT
LBL2	LAD	GR0,2
	JUMP	QUIT
LBL3	LAD	GR0,3
	JUMP	QUIT
LBL4	LAD	GR0,4
	JUMP	QUIT
LBL5	LAD	GR0,5
	JUMP	QUIT
QUIT	ST	GR0,GRADE
	RET
;
SCORE	DC	80
GRADE	DS	1
	END