EX33	START
	LD	GR1,TXT
	LD	GR2,PAT
	LD	GR3,LEN
	LAD	GR4,1
	XOR	GR5,GR5
	LAD	GR0,16
	SUBA	GR0,GR3
;
	LD	GR6,GR4
	SLL	GR6,0,GR3
	SUBA	GR6,GR4
;
LOOP	LD	GR7,GR1
	SRL	GR7,0,GR5
	AND	GR7,GR6
	XOR	GR7,GR2
	JZE	QUIT
	CPA	GR0,GR5
	JZE	NFOUND
	ADDA	GR5,GR4
	JUMP	LOOP
;
QUIT	ADDA	GR3,GR5
	SUBA	GR3,GR4
	JUMP	FIN
;
NFOUND	LAD	GR3,#FFFF
FIN	ST	GR3,POS
	RET
;
TXT	DC	#F000
PAT	DC	#000F
LEN	DC	4
POS	DS	1
	END
