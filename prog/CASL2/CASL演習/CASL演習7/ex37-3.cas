EX37_3	START
	IN	BUFF,LEN
	LD	GR1,LEN
	LAD	GR2,#0020	;Ź¬•¶Žš‘ĺ•¶Žš•ĎŠ·—p
	LAD	GR7,1
;
LOOP	SUBL	GR1,GR7
	JMI	QUIT
	LD	GR0,BUFF,GR1
	CPA	GR0,='A'
	JMI	LOOP
	CPA	GR0,='Z'
	JZE	LARGE
	JMI	LARGE
	CPA	GR0,='a'
	JMI	LOOP
	CPA	GR0,='z'
	JZE	SMALL
	JMI	SMALL
	JUMP	LOOP
;
LARGE	ADDL	GR0,GR2
	ST	GR0,BUFF,GR1
	JUMP	LOOP
;
SMALL	SUBL	GR0,GR2
	ST	GR0,BUFF,GR1
	JUMP	LOOP
;
QUIT	OUT	BUFF,LEN
	RET
;
LEN	DS	1
BUFF	DS	20
	END