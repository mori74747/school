EX38	START
	IN	BUFF,LEN
	LD	GR2,LEN
	LAD	GR7,1
	XOR	GR4,GR4
	XOR	GR5,GR5		;ANS
	LAD	GR6,#000F
LOOP	CPA	GR2,GR4
	JZE	QUIT
	LD	GR1,GR5
	SLL	GR5,3
	ADDL	GR5,GR1
	ADDL	GR5,GR1
	LD	GR0,BUFF,GR4
	AND	GR0,GR6
	ADDL	GR5,GR0
	ADDL	GR4,GR7
	JUMP	LOOP
QUIT	ST	GR5,NUM
	RET
;
BUFF	DS	5
LEN	DS	1
NUM	DS	1
	END