EX35	START
	LD	GR1,A
	LD	GR2,B
	JZE	OUT
	LD	GR6,GR2
	XOR	GR3,GR3
	LAD	GR5,#0001
;
BSHIFT	CPL	GR1,GR2
	JMI	LOOP
	JZE	LOOP
	SLL	GR5,1
	SLL	GR2,1
	JMI	LOOP
	JUMP	BSHIFT
;
LOOP	CPL	GR1,GR6
	JMI	QUIT
	CPL	GR1,GR2
	JMI	SET
	SUBL	GR1,GR2
	OR	GR3,GR5
;
SET	SRL	GR2,1
	SRL	GR5,1
	JUMP	LOOP
;
QUIT	LD	GR4,GR1
	ST	GR3,Q
	ST	GR4,R
OUT	RET
;
A	DC	#ABCD
B	DC	#1234
Q	DS	1
R	DS	1
	END
	