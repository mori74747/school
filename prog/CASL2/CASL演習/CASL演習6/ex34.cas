EX34	START
	LD	GR1,A
	LD	GR2,B
	XOR	GR3,GR3
	XOR	GR4,GR4
	XOR	GR7,GR7
	LD	GR1,GR1
	JZE	QUIT
LOOP	LD	GR2,GR2
	JZE	QUIT
	LD	GR5,GR2
	AND	GR5,=#0001
	JZE	SHIFT
	ADDL	GR4,GR7
	ADDL	GR3,GR1
	JOV	CARRY
	JUMP	SHIFT
CARRY	LAD	GR4,1,GR4
SHIFT	SRL	GR2,1
	SLL	GR7,1
	SLL	GR1,1
	JOV	LBL
	JUMP	LOOP
LBL	LAD	GR7,1,GR7
	JUMP	LOOP
QUIT	LAD	GR5,C
	ST	GR4,0,GR5
	ST	GR3,1,GR5
	RET
A	DC	#1234
B	DC	#ABCD
C	DS	2
	END