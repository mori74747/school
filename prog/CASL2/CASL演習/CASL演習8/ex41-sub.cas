SFTMUL	START
	PUSH	0,GR5
	PUSH	0,GR6
	PUSH	0,GR7
	PUSH	0,GR1
	PUSH	0,GR2
;
	XOR	GR3,GR3
	XOR	GR4,GR4
	LAD	GR6,#0001
	XOR	GR7,GR7
	LD	GR1,GR1
	JZE	QUIT
LOOP	LD	GR2,GR2
	JZE	QUIT
	LD	GR5,GR2
	AND	GR5,GR6
	JZE	SHIFT
	ADDL	GR4,GR7
	ADDL	GR3,GR1
	JOV	CARRY
	JUMP	SHIFT
CARRY	LAD	GR4,1,GR4
SHIFT	SRL	GR2,1
	SLL	GR7,1
	SLL	GR1,1
	JOV	LBL
	JUMP	LOOP
LBL	LAD	GR7,1,GR7
	JUMP	LOOP
QUIT	POP	GR2
	POP	GR1
	POP	GR7
	POP	GR6
	POP	GR5
	RET
	END